# Copy this file to .env and fill in your values
ANTHROPIC_API_KEY=sk-ant-...

# Tavily API key for agentic web lookup (get one free at https://tavily.com)
# If not set, falls back to DuckDuckGo (no key needed but less reliable)
TAVILY_API_KEY=tvly-...

# Optional: set confidence threshold below which items are escalated
ESCALATION_THRESHOLD=0.5

# Optional: enable/disable agentic web lookup (default: true)
ENABLE_LOOKUP=true

# Optional: max web search results to retrieve per lookup
LOOKUP_MAX_RESULTS=5
